# ──────────────────────────────────────────────────────────────────────────────
# Frontend — Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────────────────────────────────────

# Your Render backend URL (set this on Vercel dashboard after deploying backend)
# Example: https://blood-bank-api.onrender.com
# Leave EMPTY for local development (Vite proxy handles /api → localhost:5000)
VITE_API_URL=https://your-render-backend.onrender.com
